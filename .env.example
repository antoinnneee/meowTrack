# Configuration meowtrack — copier en .env et remplir (lu par server.js via dotenv,
# et par l'unité systemd via EnvironmentFile). Le MCP local n'en a pas besoin.

# Hôte d'écoute. Local : 127.0.0.1. Déploiement (joignable sur le réseau) : 0.0.0.0
MEOWTRACK_HOST=0.0.0.0

# Port dédié du dashboard (choisir un port LIBRE sur le serveur, PAS 80).
MEOWTRACK_PORT=7702

# Token d'accès à l'API. OBLIGATOIRE en déploiement (sinon API ouverte à tout le
# réseau). Générer : node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Utilisé à la fois par le serveur (validation) ET par le MCP (en-tête Bearer).
MEOWTRACK_TOKEN=

# [Client MCP uniquement] URL de base de l'API du serveur distant. Le MCP (mcp.js)
# relaie TOUTES ses requêtes vers ce serveur (pas de base locale). Défini aussi
# dans .mcp.json. Défaut : http://127.0.0.1:7702. Ex prod : http://pattounecorp.ovh:7702
MEOWTRACK_SERVER_URL=

# [Client MCP, optionnel] Repo par défaut (slug ou id) appliqué aux outils MCP
# quand l'appel ne précise pas `repo`. Vide : le serveur retombe sur SON repo par
# défaut (is_default du registre). Ex : meownopoly
MEOWTRACK_DEFAULT_REPO=

# ── MULTI-REPOS ───────────────────────────────────────────────────────────────
# meowtrack suit PLUSIEURS dépôts git (registre en base, table `repos`). Chaque
# entrée/nœud est scopé par repo ; on ajoute/retire des repos à chaud via le
# dashboard (sélecteur + « ＋ repo ») ou les outils MCP (meowtrack_repo_add/_remove/
# _update). Les repos avec URL sont clonés dans meowtrack/.repos/<slug>/.
#
# Les deux variables ci-dessous ne servent qu'au BOOTSTRAP : sur une base VIERGE
# (ou migrée depuis l'ancien mono-repo), elles créent le repo PAR DÉFAUT. Une fois
# le registre peuplé, elles sont ignorées (les repos vivent en base).

# URL git du repo PAR DÉFAUT à cloner au premier démarrage. Laisser vide pour un
# clone géré à la main / dev in-repo. Ex : https://github.com/antoinnneee/meownopoly.git
MEOWTRACK_REPO_URL=

# Chemin ABSOLU d'un clone existant pour le repo PAR DÉFAUT (override de .repos/<slug>/).
# Si MEOWTRACK_REPO_URL est aussi défini, ce chemin devient la destination du clone.
# Si les deux sont vides, le repo par défaut pointe le checkout courant (dev in-repo).
# Ex : /home/meow-server/meownopoly
MEOWTRACK_REPO=

# Chemin de la base de REGISTRE SQLite (registre des dépôts + réglages d'instance ;
# défaut : meowtrack.db à côté du service). Les DONNÉES de tracking ne vivent PAS ici :
# chaque dépôt a sa propre base .trackers/<slug>/tracker.db (cloisonnement par dépôt).
# MEOWTRACK_DB=/home/meow-server/meowtrack/meowtrack.db

# ── Versionnement git du tracking PAR dépôt (Option B : branche orphan + worktree) ──
# DÉSACTIVÉ par défaut. Si activé, la base tracker.db de chaque dépôt est versionnée
# dans une branche ORPHAN « tracking » (aucun historique commun avec le code), via un
# worktree dédié .trackers/<slug>/ — les branches de code ne sont JAMAIS touchées.
# Un committer périodique commit les changements ; un commit final a lieu à l'arrêt.
# Le commit est LOCAL (sûr) ; le push (publication vers le remote) est opt-in SÉPARÉ.
# MEOWTRACK_TRACKING_GIT=0          # 1 = activer worktree + commit local automatique
# MEOWTRACK_TRACKING_PUSH=0         # 1 = pousser la branche tracking vers le remote
# MEOWTRACK_TRACKING_BRANCH=tracking
# MEOWTRACK_TRACKING_REMOTE=origin
# MEOWTRACK_TRACKING_INTERVAL_MS=5000   # cadence du committer (débounce ~5 s)
# MEOWTRACK_TRACKING_NAME=meowtrack     # identité de commit dédiée (n'altère pas ta config git)
# MEOWTRACK_TRACKING_EMAIL=meowtrack@localhost

# [Serveur] Binaire CLI Claude pour les features IA (chat Good Vibes + « Améliorer
# la description »). Le CLI doit être installé ET authentifié sur la machine. Défaut : claude
# MEOWTRACK_CLAUDE_BIN=claude

# [Serveur] client_id d'une OAuth App GitHub pour le bouton « Se connecter à GitHub »
# du gestionnaire de repos (page Config → GitHub), qui authentifie git en HTTPS pour
# push/pull SANS prompt (impossible côté serveur sans TTY). Création (une fois) :
# github.com/settings/developers → New OAuth App → cocher « Enable Device Flow »,
# puis copier le Client ID ici. Ce n'est PAS un secret (pas de client_secret en device
# flow). Le token obtenu est stocké dans le credential store git (~/.git-credentials).
# MEOWTRACK_GITHUB_CLIENT_ID=

# [Serveur] Accès LECTURE du dépôt par le chat IA de Good Vibes (pour discuter du
# code réel). Défaut activé (1). Mettre à 0 pour verrouiller (le bot raisonne alors
# sans accès fichier). Même activé, le bot est en LECTURE SEULE (Read/Glob/Grep),
# sans écriture/shell/réseau, sans le token (env minimal), et les fichiers sensibles
# (.env, clés, bases, .git) lui sont refusés. En déploiement, l'accès porte sur le
# CLONE (MEOWTRACK_REPO/REPO_URL) qui ne contient AUCUN secret gitignoré.
# MEOWTRACK_AI_REPO_ACCESS=1
